# Public website
NEXT_PUBLIC_SITE_URL=https://your-domain.example
NEXT_PUBLIC_WHATSAPP_NUMBER=2376XXXXXXXX
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Consent and form security
CONSENT_TEXT_VERSION=2026-07-v1
TURNSTILE_SECRET_KEY=
FORM_RATE_LIMIT_MAX=12
FORM_RATE_LIMIT_WINDOW_MS=60000

# Dedicated GoHighLevel inbound workflow URLs
GHL_KITCHEN_APPLICATION_WEBHOOK_URL=
GHL_ORDER_REQUEST_WEBHOOK_URL=
GHL_GROUP_ORDER_WEBHOOK_URL=
GHL_CONTACT_WEBHOOK_URL=
